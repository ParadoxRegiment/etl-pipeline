# Copy to .env and adjust. .env is gitignored.

# --- Warehouse Postgres (docker-compose service `warehouse`) ---
WAREHOUSE_DB_USER=etl
WAREHOUSE_DB_PASSWORD=etl
WAREHOUSE_DB_NAME=earthquakes
WAREHOUSE_DB_PORT=5432

# Connection string used by the app (psycopg 3 driver).
# host is localhost when running the app on your machine against the container;
# it becomes the service name (`warehouse`) once the app itself runs in compose.
WAREHOUSE_DATABASE_URL=postgresql+psycopg://etl:etl@localhost:5432/earthquakes

# --- USGS API ---
USGS_API_URL=https://earthquake.usgs.gov/fdsnws/event/1/query
